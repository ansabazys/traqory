{
  "name": "@traqory/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./schema/auth": {
      "types": "./dist/schema/auth/auth.schema.d.ts",
      "default": "./dist/schema/auth/auth.schema.js",
      "import": "./dist/schema/auth/auth.schema.js"
    },
    "./schema/analytics": {
      "types": "./dist/schema/analytics/index.d.ts",
      "default": "./dist/schema/analytics/index.js",
      "import": "./dist/schema/analytics/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
